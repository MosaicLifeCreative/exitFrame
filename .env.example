# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
UPSTASH_REDIS_URL=rediss://default:your-token@your-redis.upstash.io:6379

# tastytrade (Production — read-only)
TASTYTRADE_CLIENT_SECRET=your-client-secret
TASTYTRADE_REFRESH_TOKEN=your-refresh-token

# tastytrade (Sandbox — Ayden paper trading)
TASTYTRADE_SANDBOX_CLIENT_ID=your-sandbox-client-id
TASTYTRADE_SANDBOX_CLIENT_SECRET=your-sandbox-client-secret
TASTYTRADE_SANDBOX_REFRESH_TOKEN=your-sandbox-refresh-token

# OpenAI (embeddings only — text-embedding-3-small)
OPENAI_API_KEY=sk-your-openai-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
