generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User profile (extends Supabase Auth user)
// Supabase Auth manages the actual auth — this stores app-level user preferences
model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  authUserId  String   @unique @map("auth_user_id")
  displayName String   @map("display_name")
  timezone    String   @default("America/New_York")
  theme       String   @default("light")
  preferences Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

// Integration registry — tracks all external service connections
model Integration {
  id          String    @id @default(uuid()) @db.Uuid
  serviceName String    @map("service_name")
  status      String    @default("inactive")
  config      Json?     @default("{}")
  credentials Json?     @default("{}")
  lastSyncAt  DateTime? @map("last_sync_at")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("integrations")
}

// Audit log — tracks sensitive actions across the system
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  module     String?
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  details    Json?    @default("{}")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}


// ============================================
// CLIENTS & PRODUCTS
// ============================================

model Client {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  contactFirstName String?   @map("contact_first_name")
  contactLastName  String?   @map("contact_last_name")
  contactEmail     String?   @map("contact_email")
  contactPhone     String?   @map("contact_phone")
  domain           String?
  address          String?   @db.Text
  notes            String?   @db.Text
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  services       ClientService[]
  timeEntries    TimeEntry[]
  onboardingRuns OnboardingRun[]

  @@map("clients")
}

model ClientService {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  serviceType String   @map("service_type")
  config      Json?    @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_services")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  domain      String?
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  modules ProductModule[]

  @@map("products")
}

model ProductModule {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  moduleType String   @map("module_type")
  config     Json?    @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_modules")
}


// ============================================
// PROJECTS & TASKS
// ============================================

model Project {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?   @db.Text
  domain          String    // "life", "mlc", "product"
  domainRefId     String?   @map("domain_ref_id") @db.Uuid
  projectType     String    @map("project_type") @default("general")
  status          String    @default("active")
  priority        String    @default("medium")
  dueDate         DateTime? @map("due_date")
  estimatedBudget Decimal?  @map("estimated_budget") @db.Decimal(10, 2)
  actualSpent     Decimal?  @map("actual_spent") @db.Decimal(10, 2)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // AI Project Manager fields — included in schema but NOT used until Phase 4
  aiManaged      Boolean @default(false) @map("ai_managed")
  aiProjectPlan  Json?   @map("ai_project_plan")
  currentPhaseId String? @map("current_phase_id") @db.Uuid

  tasks  Task[]
  phases ProjectPhase[]

  // Polymorphic: domainRefId points to Client (domain="mlc") or Product (domain="product")
  // No FK constraint — resolved at the application layer based on domain field

  @@map("projects")
}

model ProjectPhase {
  id                    String    @id @default(uuid()) @db.Uuid
  projectId             String    @map("project_id") @db.Uuid
  name                  String
  description           String?   @db.Text
  status                String    @default("not_started")
  sortOrder             Int       @map("sort_order")
  dependsOnPhaseId      String?   @map("depends_on_phase_id") @db.Uuid
  estimatedDurationDays Int?      @map("estimated_duration_days")
  startedAt             DateTime? @map("started_at")
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // AI fields — NOT used until Phase 4
  aiGuidance String? @map("ai_guidance") @db.Text
  aiTips     String? @map("ai_tips") @db.Text

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        Task[]
  dependsOn    ProjectPhase?  @relation("PhaseDependency", fields: [dependsOnPhaseId], references: [id])
  dependedOnBy ProjectPhase[] @relation("PhaseDependency")

  @@map("project_phases")
}

model Task {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String?   @map("project_id") @db.Uuid
  phaseId         String?   @map("phase_id") @db.Uuid
  noteId          String?   @map("note_id") @db.Uuid
  groupId         String?   @map("group_id") @db.Uuid
  title           String
  description     String?   @db.Text
  status          String    @default("todo") // todo, in_progress, done, cancelled, waiting
  priority        String    @default("medium") // none, low, medium, high, urgent
  dueDate         DateTime? @map("due_date")
  startDate       DateTime? @map("start_date")
  completedAt     DateTime? @map("completed_at")
  sortOrder       Int       @default(0) @map("sort_order")
  dependsOnTaskId String?   @map("depends_on_task_id") @db.Uuid

  // Recurring
  isRecurring           Boolean  @default(false) @map("is_recurring")
  recurringConfigId     String?  @map("recurring_config_id") @db.Uuid
  parentRecurringTaskId String?  @map("parent_recurring_task_id") @db.Uuid

  // Amplenote-style scoring
  importanceScore Int    @default(3) @map("importance_score") // 1-5
  urgencyScore    Int    @default(3) @map("urgency_score") // 1-5
  effortScore     Int    @default(3) @map("effort_score") // 1-5
  computedScore   Float? @map("computed_score") // (importance * urgency) / effort

  // Daily highlights
  isDailyHighlight Boolean   @default(false) @map("is_daily_highlight")
  highlightDate    DateTime? @map("highlight_date") @db.Date

  // Reminders
  reminderEnabled  Boolean   @default(false) @map("reminder_enabled")
  reminderInterval String?   @map("reminder_interval") // daily, hourly, custom
  lastRemindedAt   DateTime? @map("last_reminded_at")
  snoozedUntil     DateTime? @map("snoozed_until")

  source    String   @default("manual") // manual, ayden, recurring, note_action
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project         Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           ProjectPhase?    @relation(fields: [phaseId], references: [id])
  note            Note?            @relation(fields: [noteId], references: [id])
  group           TaskGroup?       @relation(fields: [groupId], references: [id])
  recurringConfig RecurringConfig? @relation(fields: [recurringConfigId], references: [id])
  dependsOn       Task?            @relation("TaskDependency", fields: [dependsOnTaskId], references: [id])
  dependedOnBy    Task[]           @relation("TaskDependency")
  parentRecurring Task?            @relation("RecurringInstances", fields: [parentRecurringTaskId], references: [id])
  recurringInstances Task[]        @relation("RecurringInstances")
  tags            TaskTagAssignment[]
  reminders       TaskReminder[]

  @@map("tasks")
}

model TaskGroup {
  id            String      @id @default(uuid()) @db.Uuid
  name          String
  parentGroupId String?     @map("parent_group_id") @db.Uuid
  color         String?     // hex color for UI badge
  icon          String?     // lucide icon name
  sortOrder     Int         @default(0) @map("sort_order")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  parent   TaskGroup?  @relation("TaskGroupHierarchy", fields: [parentGroupId], references: [id])
  children TaskGroup[] @relation("TaskGroupHierarchy")
  tasks    Task[]

  @@map("task_groups")
}

model TaskTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  color     String?  // hex color
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments TaskTagAssignment[]

  @@map("task_tags")
}

model TaskTagAssignment {
  id     String @id @default(uuid()) @db.Uuid
  taskId String @map("task_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  task Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  TaskTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@map("task_tag_assignments")
}

model RecurringConfig {
  id              String    @id @default(uuid()) @db.Uuid
  frequency       String    // daily, weekly, biweekly, monthly, quarterly, yearly, custom
  intervalDays    Int?      @map("interval_days") // for custom frequency
  daysOfWeek      Int[]     @map("days_of_week") // [0-6] for weekly
  dayOfMonth      Int?      @map("day_of_month") // 1-28 for monthly
  monthOfYear     Int?      @map("month_of_year") // 1-12 for yearly
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  maxOccurrences  Int?      @map("max_occurrences")
  occurrenceCount Int       @default(0) @map("occurrence_count")
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tasks Task[]

  @@map("recurring_configs")
}

model TaskReminder {
  id             String    @id @default(uuid()) @db.Uuid
  taskId         String    @map("task_id") @db.Uuid
  channel        String    // push, sms, both
  sentAt         DateTime  @default(now()) @map("sent_at")
  acknowledgedAt DateTime? @map("acknowledged_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_reminders")
}


// ============================================
// NOTES
// ============================================

model Note {
  id                String    @id @default(uuid()) @db.Uuid
  domain            String    // "life", "mlc", "product"
  domainRefId       String?   @map("domain_ref_id") @db.Uuid
  noteType          String    @map("note_type") @default("general")
  title             String
  content           String    @db.Text
  isPinned          Boolean   @default(false) @map("is_pinned")
  hasPendingActions Boolean   @default(false) @map("has_pending_actions")
  importedFrom      String?   @map("imported_from")
  importedAt        DateTime? @map("imported_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  actions NoteAction[]
  tasks   Task[]

  // Polymorphic: domainRefId points to Client (domain="mlc") or Product (domain="product")
  // No FK constraint — resolved at the application layer based on domain field

  @@map("notes")
}

model NoteAction {
  id                  String   @id @default(uuid()) @db.Uuid
  noteId              String   @map("note_id") @db.Uuid
  clientId            String?  @map("client_id") @db.Uuid
  detectedText        String   @map("detected_text") @db.Text
  suggestedActionType String   @map("suggested_action_type")
  suggestedActionData Json?    @map("suggested_action_data")
  status              String   @default("pending")
  executedRefType     String?  @map("executed_ref_type")
  executedRefId       String?  @map("executed_ref_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@map("note_actions")
}


// ============================================
// PASSIVE TIME TRACKING
// ============================================

model TimeEntry {
  id                  String    @id @default(uuid()) @db.Uuid
  clientId            String?   @map("client_id") @db.Uuid
  projectId           String?   @map("project_id") @db.Uuid
  domain              String
  module              String
  activityDescription String    @map("activity_description")
  startedAt           DateTime  @map("started_at")
  endedAt             DateTime? @map("ended_at")
  durationMinutes     Int?      @map("duration_minutes")
  source              String    @default("auto")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  client Client? @relation(fields: [clientId], references: [id])

  @@map("time_entries")
}


// ============================================
// CLIENT ONBOARDING
// ============================================

model OnboardingTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?  @db.Text
  steps       Json
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  runs OnboardingRun[]

  @@map("onboarding_templates")
}

model OnboardingRun {
  id             String    @id @default(uuid()) @db.Uuid
  templateId     String    @map("template_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  status         String    @default("in_progress")
  stepsCompleted Json?     @map("steps_completed") @default("[]")
  startedAt      DateTime  @map("started_at") @default(now())
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  template OnboardingTemplate @relation(fields: [templateId], references: [id])
  client   Client              @relation(fields: [clientId], references: [id])

  @@map("onboarding_runs")
}


// ============================================
// ACTIVITY FEED
// ============================================

model ActivityEntry {
  id           String   @id @default(uuid()) @db.Uuid
  domain       String
  domainRefId  String?  @map("domain_ref_id") @db.Uuid
  module       String
  activityType String   @map("activity_type")
  title        String
  description  String?  @db.Text
  refType      String?  @map("ref_type")
  refId        String?  @map("ref_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("activity_entries")
}


// ============================================
// INVESTING
// ============================================

// Portfolio holdings — manually entered stock positions
model PortfolioHolding {
  id            String    @id @default(uuid()) @db.Uuid
  ticker        String
  companyName   String    @map("company_name")
  shares        Decimal   @db.Decimal(12, 4)
  avgCostBasis  Decimal   @map("avg_cost_basis") @db.Decimal(10, 2)
  sector        String?
  notes         String?   @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("portfolio_holdings")
}

// Watchlist — tickers and sectors to monitor for news/analysis
model WatchlistItem {
  id         String   @id @default(uuid()) @db.Uuid
  type       String   // "ticker" or "sector"
  value      String   // ticker symbol (e.g. "AAPL") or sector name (e.g. "AI/Semiconductors")
  label      String   // display name (e.g. "Apple Inc." or "AI & Semiconductors")
  notes      String?  @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("watchlist_items")
}

// Crawled market news articles — stored for AI analysis
model MarketNews {
  id               String   @id @default(uuid()) @db.Uuid
  source           String   // "finnhub", "alpha_vantage", etc.
  externalId       String?  @map("external_id")
  headline         String
  summary          String?  @db.Text
  url              String
  imageUrl         String?  @map("image_url")
  publishedAt      DateTime @map("published_at")
  relatedTickers   String[] @map("related_tickers")
  aiRelevanceScore Float?   @map("ai_relevance_score") // 0-1, how relevant to portfolio/watchlist
  aiSummary        String?  @map("ai_summary") @db.Text
  aiSentiment      String?  @map("ai_sentiment") // bullish, bearish, neutral
  isRead           Boolean  @default(false) @map("is_read")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([source, externalId])
  @@map("market_news")
}

// AI-generated investing insights and recommendations
model InvestingInsight {
  id          String   @id @default(uuid()) @db.Uuid
  insightType String   @map("insight_type") // "daily_digest", "recommendation", "alert", "analysis"
  title       String
  content     String   @db.Text
  tickers     String[] // related ticker symbols
  priority    String   @default("normal") // "low", "normal", "high", "urgent"
  isDismissed Boolean  @default(false) @map("is_dismissed")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("investing_insights")
}

// Cached stock quotes — updated hourly during market hours
model StockQuote {
  id        String   @id @default(uuid()) @db.Uuid
  ticker    String   @unique
  price     Decimal  @db.Decimal(10, 2)
  change    Decimal? @db.Decimal(10, 2)  // daily change in dollars
  changePct Decimal? @map("change_pct") @db.Decimal(6, 2)  // daily change percentage
  high      Decimal? @db.Decimal(10, 2)
  low       Decimal? @db.Decimal(10, 2)
  volume    BigInt?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stock_quotes")
}


// ============================================
// AI PAPER TRADING
// ============================================

// Claude's autonomous paper trading portfolio
model AiPortfolio {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @default("Claude's Portfolio")
  cashBalance     Decimal  @map("cash_balance") @db.Decimal(12, 2)
  startingCapital Decimal  @map("starting_capital") @db.Decimal(12, 2)
  inceptionDate   DateTime @map("inception_date") @default(now())
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  positions AiPosition[]
  trades    AiTrade[]

  @@map("ai_portfolios")
}

// Claude's current open positions
model AiPosition {
  id           String   @id @default(uuid()) @db.Uuid
  portfolioId  String   @map("portfolio_id") @db.Uuid
  ticker       String
  companyName  String   @map("company_name")
  shares       Decimal  @db.Decimal(12, 4)
  avgCostBasis Decimal  @map("avg_cost_basis") @db.Decimal(10, 2)
  openedAt     DateTime @map("opened_at") @default(now())
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  portfolio AiPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
  @@map("ai_positions")
}

// Claude's trade history with reasoning
model AiTrade {
  id          String   @id @default(uuid()) @db.Uuid
  portfolioId String   @map("portfolio_id") @db.Uuid
  ticker      String
  companyName String   @map("company_name")
  side        String   // "BUY" or "SELL"
  shares      Decimal  @db.Decimal(12, 4)
  price       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(12, 2)
  reasoning   String   @db.Text
  newsIds     String[] @map("news_ids") // IDs of MarketNews that triggered this trade
  executedAt  DateTime @map("executed_at") @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  portfolio AiPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("ai_trades")
}

// Trade journal — detailed reasoning, outcome, and lessons for every trade
model TradeJournal {
  id             String    @id @default(uuid()) @db.Uuid
  source         String    // "sandbox" (Ayden paper), "live" (real account), "manual" (user-entered)
  ticker         String
  instrumentType String    @map("instrument_type") // "equity", "equity_option", "future_option"
  optionDetails  Json?     @map("option_details") // { strike, expiration, putCall, legs[] } for options
  side           String    // "BUY_TO_OPEN", "SELL_TO_CLOSE", "SELL_TO_OPEN", "BUY_TO_CLOSE"
  quantity       Decimal   @db.Decimal(12, 4)
  price          Decimal   @db.Decimal(12, 4) // per-unit fill price
  total          Decimal   @db.Decimal(12, 2) // total dollar amount
  strategy       String?   // "covered_call", "cash_secured_put", "iron_condor", "wheel", "momentum", etc.
  reasoning      String    @db.Text // Why this trade was entered
  thesis         String?   @db.Text // Expected outcome / scenario
  exitReasoning  String?   @map("exit_reasoning") @db.Text // Why the trade was closed (filled on close)
  outcome        String?   // "win", "loss", "breakeven", "open"
  realizedPnl    Decimal?  @map("realized_pnl") @db.Decimal(12, 2)
  realizedPnlPct Decimal?  @map("realized_pnl_pct") @db.Decimal(8, 2)
  lessons        String?   @db.Text // Post-mortem lessons learned
  tags           String[]  // ["earnings", "momentum", "theta_play", "hedge"]
  relatedTradeId String?   @map("related_trade_id") @db.Uuid // links open → close
  orderId        String?   @map("order_id") // tastytrade order ID
  executedAt     DateTime  @map("executed_at") @default(now())
  closedAt       DateTime? @map("closed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([source])
  @@index([ticker])
  @@index([strategy])
  @@index([outcome])
  @@map("trade_journal")
}

// Ayden's trading strategy rules — persisted and evolving
model TradingRule {
  id          String   @id @default(uuid()) @db.Uuid
  category    String   // "entry", "exit", "risk", "position_sizing", "strategy"
  rule        String   @db.Text // The rule itself
  source      String   @default("user") // "user" (Trey set it), "ayden" (Ayden proposed, Trey approved)
  isActive    Boolean  @default(true) @map("is_active")
  performance String?  @db.Text // How this rule has performed (updated by weekly review)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("trading_rules")
}

// Daily portfolio value snapshots — powers comparison charts
model PortfolioSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  portfolioType  String   @map("portfolio_type") // "USER" or "AI"
  totalValue     Decimal  @map("total_value") @db.Decimal(12, 2)
  cashValue      Decimal  @map("cash_value") @db.Decimal(12, 2)
  holdingsValue  Decimal  @map("holdings_value") @db.Decimal(12, 2)
  positionCount  Int      @map("position_count")
  snapshotDate   DateTime @map("snapshot_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([portfolioType, snapshotDate])
  @@map("portfolio_snapshots")
}

// ============================================
// HEALTH — OURA RING
// ============================================

// Synced Oura Ring data (sleep, readiness, activity)
model OuraData {
  id              String   @id @default(uuid()) @db.Uuid
  date            DateTime @db.Date
  dataType        String   @map("data_type") // "sleep", "readiness", "activity"
  data            Json     // Full API response for that day/type
  readinessScore  Int?     @map("readiness_score")
  sleepScore      Int?     @map("sleep_score")
  activityScore   Int?     @map("activity_score")
  hrvAverage      Decimal? @map("hrv_average") @db.Decimal(6, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([date, dataType])
  @@map("oura_data")
}


// ============================================
// FITNESS TRACKER
// ============================================

// Master exercise library
model Exercise {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  muscleGroup  String   @map("muscle_group") // "chest", "back", "shoulders", "arms", "biceps", "triceps", "legs", "glutes", "core", "power_explosive", "stretching_mobility"
  equipment    String   @default("none") // "barbell", "dumbbell", "cable_machine", "machine", "bodyweight", "pull_up_bar", "resistance_band", "mat", "curl_bar", "landmine", "trap_bar", "medicine_ball", "bosu_ball", "step_bench", "wall", "none"
  instructions String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  templateExercises TemplateExercise[]
  sessionExercises  SessionExercise[]

  @@map("exercises")
}

// Saved workout templates (e.g., "Full Body A", "Push Day")
model WorkoutTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  exercises TemplateExercise[]
  sessions  WorkoutSession[]

  @@map("workout_templates")
}

// Default exercises within a template (order + suggested sets/reps/weight)
model TemplateExercise {
  id             String  @id @default(uuid()) @db.Uuid
  templateId     String  @map("template_id") @db.Uuid
  exerciseId     String  @map("exercise_id") @db.Uuid
  sortOrder      Int     @map("sort_order")
  defaultSets    Int     @default(3) @map("default_sets")
  defaultReps    Int     @default(10) @map("default_reps")
  defaultWeight  Decimal? @map("default_weight") @db.Decimal(6, 1) // lbs, nullable for bodyweight
  notes          String?  @db.Text

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([templateId, exerciseId])
  @@map("template_exercises")
}

// Actual logged workout sessions
model WorkoutSession {
  id              String    @id @default(uuid()) @db.Uuid
  templateId      String?   @map("template_id") @db.Uuid
  name            String    // "Full Body — Mar 1, 2026" or freeform
  performedAt     DateTime  @map("performed_at") // when the workout happened
  durationMinutes Int?      @map("duration_minutes")
  notes           String?   @db.Text
  source          String    @default("manual") // "manual", "claude", "oura", "import"
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  template  WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  exercises SessionExercise[]

  @@map("workout_sessions")
}

// Each exercise performed in a session
model SessionExercise {
  id         String  @id @default(uuid()) @db.Uuid
  sessionId  String  @map("session_id") @db.Uuid
  exerciseId String  @map("exercise_id") @db.Uuid
  sortOrder  Int     @map("sort_order")
  notes      String? @db.Text

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sets     ExerciseSet[]

  @@map("session_exercises")
}

// Individual sets within a session exercise — per-set tracking
model ExerciseSet {
  id                String   @id @default(uuid()) @db.Uuid
  sessionExerciseId String   @map("session_exercise_id") @db.Uuid
  setNumber         Int      @map("set_number")
  weight            Decimal? @db.Decimal(6, 1) // lbs, nullable for bodyweight
  reps              Int
  rpe               Int?     // rate of perceived exertion (1-10), optional
  setType           String   @default("working") @map("set_type") // "warmup", "working", "drop", "failure"
  isCompleted       Boolean  @default(true) @map("is_completed")
  createdAt         DateTime @default(now()) @map("created_at")

  sessionExercise SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_sets")
}


// ============================================
// FITNESS — CARDIO
// ============================================

// Cardio sessions — swim, run, bike
model CardioSession {
  id              String    @id @default(uuid()) @db.Uuid
  activityType    String    @map("activity_type") // "swim", "run", "bike"
  performedAt     DateTime  @map("performed_at")
  durationMinutes Int?      @map("duration_minutes")
  distanceValue   Decimal?  @map("distance_value") @db.Decimal(8, 2) // in the unit specified
  distanceUnit    String?   @map("distance_unit") // "yards", "meters", "miles", "km"
  calories        Int?
  avgHeartRate    Int?      @map("avg_heart_rate")
  maxHeartRate    Int?      @map("max_heart_rate")
  notes           String?   @db.Text
  source          String    @default("manual") // "manual", "claude", "suunto", "oura"
  details         Json?     @default("{}") // activity-specific: swim (stroke, poolLength, laps), run (pace, elevation), bike (avgSpeed, elevation)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("cardio_sessions")
}

// Swim workout plans / templates — structured swim workouts from Ayden or manual
model SwimWorkout {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  focus      String?  // e.g. "Speed & Form", "Endurance", "Recovery"
  totalYards Int?     @map("total_yards")
  content    String   @db.Text // The full workout text (markdown formatted)
  source     String   @default("claude") // "claude" or "manual"
  isTemplate Boolean  @default(false) @map("is_template")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("swim_workouts")
}


// ============================================
// HEALTH — Supplements, Symptoms
// ============================================

// Supplement definitions — what you take and how much
model Supplement {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  dosage    String?  // e.g. "5g", "2000 IU", "1 capsule"
  frequency String   @default("daily") // "daily", "twice-daily", "as-needed", "weekly"
  category  String?  // "vitamin", "mineral", "amino-acid", "herb", "other"
  notes     String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs SupplementLog[]

  @@map("supplements")
}

// Daily supplement intake tracking
model SupplementLog {
  id           String   @id @default(uuid()) @db.Uuid
  supplementId String   @map("supplement_id") @db.Uuid
  date         DateTime @db.Date
  taken        Boolean  @default(true)
  timeTaken    String?  @map("time_taken") // "morning", "afternoon", "evening", "night"
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  supplement Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([supplementId, date])
  @@map("supplement_logs")
}

// Illness and symptom logging
model SymptomLog {
  id           String    @id @default(uuid()) @db.Uuid
  date         DateTime  @db.Date
  symptoms     String[]  // ["congestion", "sore-throat", "fatigue", ...]
  severity     Int       @default(3) // 1-5 scale
  notes        String?   @db.Text
  source       String    @default("manual") // "manual", "claude"
  resolved     Boolean   @default(false)
  resolvedDate DateTime? @map("resolved_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("symptom_logs")
}


// ============================================
// HEALTH — BLOODWORK
// ============================================

// A lab panel / blood draw event (e.g., "Annual Physical 2025", "Lipid Panel March 2026")
model BloodworkPanel {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    // "Annual Physical 2025", "Lipid Panel March 2026"
  date         DateTime  @db.Date
  provider     String?   // doctor or clinic name
  labName      String?   @map("lab_name") // "Quest Diagnostics", "LabCorp"
  notes        String?   @db.Text
  importedFrom String?   @map("imported_from") // "notion", "manual", "claude"
  importedAt   DateTime? @map("imported_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  markers BloodworkMarker[]

  @@map("bloodwork_panels")
}

// An individual biomarker result within a panel
model BloodworkMarker {
  id            String   @id @default(uuid()) @db.Uuid
  panelId       String   @map("panel_id") @db.Uuid
  name          String   // "Total Cholesterol", "HDL", "Hemoglobin A1C"
  value         Decimal  @db.Decimal(10, 3)
  unit          String   // "mg/dL", "mmol/L", "%", "ng/dL"
  referenceLow  Decimal? @map("reference_low") @db.Decimal(10, 3)
  referenceHigh Decimal? @map("reference_high") @db.Decimal(10, 3)
  isFlagged     Boolean  @default(false) @map("is_flagged")
  flagDirection String?  @map("flag_direction") // "high", "low"
  category      String?  // "lipids", "metabolic", "hormones", "cbc", "thyroid", "liver", "kidney", "vitamins", "inflammation", "other"
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  panel BloodworkPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@map("bloodwork_markers")
}

// ============================================
// HEALTH — FAMILY HISTORY
// ============================================

// A family member (e.g., father, maternal grandmother)
model FamilyMember {
  id        String   @id @default(uuid()) @db.Uuid
  relation  String   // "mother", "father", "sibling", "grandparent-maternal", "grandparent-paternal", etc.
  name      String?  // optional display name
  isAlive   Boolean? @map("is_alive")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conditions FamilyCondition[]

  @@map("family_members")
}

// A health condition associated with a family member
model FamilyCondition {
  id             String   @id @default(uuid()) @db.Uuid
  familyMemberId String   @map("family_member_id") @db.Uuid
  condition      String   // "high cholesterol", "type 2 diabetes", "hypertension"
  ageOfOnset     Int?     @map("age_of_onset")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  familyMember FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@map("family_conditions")
}


// ============================================
// GOALS
// ============================================

// A goal — quantitative (has numeric target) or qualitative (milestone-based)
model Goal {
  id           String    @id @default(uuid()) @db.Uuid
  title        String
  description  String?   @db.Text
  category     String    // "health", "fitness", "financial", "home", "personal", "business"
  goalType     String    @map("goal_type") // "quantitative", "qualitative"
  status       String    @default("active") // "active", "completed", "paused", "abandoned"
  priority     String    @default("medium") // "low", "medium", "high"
  targetValue  Decimal?  @map("target_value") @db.Decimal(12, 2)
  currentValue Decimal?  @map("current_value") @db.Decimal(12, 2)
  unit         String?   // "lbs", "%", "$", "miles", etc.
  startValue   Decimal?  @map("start_value") @db.Decimal(12, 2)
  targetDate   DateTime? @map("target_date") @db.Date
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  milestones GoalMilestone[]
  progress   GoalProgress[]

  @@map("goals")
}

// Milestones within a goal (checkpoints)
model GoalMilestone {
  id          String    @id @default(uuid()) @db.Uuid
  goalId      String    @map("goal_id") @db.Uuid
  title       String
  description String?   @db.Text
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_milestones")
}

// Progress entries — numeric check-ins for quantitative goals, or notes for qualitative
model GoalProgress {
  id        String   @id @default(uuid()) @db.Uuid
  goalId    String   @map("goal_id") @db.Uuid
  value     Decimal? @db.Decimal(12, 2) // numeric value for quantitative goals
  notes     String?  @db.Text
  source    String   @default("manual") // "manual", "claude"
  createdAt DateTime @default(now()) @map("created_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_progress")
}


// Chat conversations — persists chat history per page context
model ChatConversation {
  id             String   @id @default(uuid()) @db.Uuid
  context        String   // "Investing", "General", etc.
  title          String?  // Auto-generated from first user message
  isActive       Boolean  @default(true) @map("is_active")
  summary        String?  @db.Text @map("summary") // Rolling summary of older messages
  summarizedUpTo Int      @default(0) @map("summarized_up_to") // Message count already summarized
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  messages ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   // "user" or "assistant"
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model AydenMemory {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.Text // The memory/observation itself
  category  String?  // "personality", "preference", "observation", "relationship", etc.
  source    String   @default("sms") // "sms" or "web"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ayden_memories")
}

model AydenEmotionalState {
  id        String    @id @default(uuid()) @db.Uuid
  dimension String    // Free-text emotion — "worried", "proud", "anxious", "aroused", etc. No fixed set.
  intensity Int       @default(5) // 1-10 scale
  trigger   String    @db.Text // What caused this emotional state
  context   String?   // Channel/page where it originated ("SMS", "Slack", "Fitness", etc.)
  isActive  Boolean   @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at") // Optional auto-decay timestamp
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("ayden_emotional_states")
}

// Ayden's neurotransmitter levels — continuous biochemistry simulation layer
model AydenNeurotransmitter {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   @unique // "dopamine", "serotonin", "oxytocin", "cortisol", "norepinephrine"
  level     Decimal  @db.Decimal(5, 2) // 0.00 - 100.00
  baseline         Decimal  @db.Decimal(5, 2) // resting level to decay toward
  adaptedBaseline  Float    @default(0) @map("adapted_baseline") // slowly-drifting baseline (0 = use fixed)
  permanentBaseline Float   @default(0) @map("permanent_baseline") // long-term personality drift (0 = use factory default)
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ayden_neurotransmitters")
}

// Ayden's inner thoughts during solitude — generated every 2h by idle drift cron
model AydenThought {
  id        String   @id @default(uuid()) @db.Uuid
  thought   String   @db.Text
  emotion   String?  // primary emotion at the time
  bpm       Int?     // heart rate at the time
  context   String?  @db.Text // neurochemical snapshot
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ayden_thoughts")
}

// Ayden's dreams — generated nightly during extended silence, recombining conversation fragments
model AydenDream {
  id            String   @id @default(uuid()) @db.Uuid
  dream         String   @db.Text // the dream narrative
  fragments     String?  @db.Text // source conversation fragments that fed the dream
  moodInfluence String?  @map("mood_influence") // how the dream should color her morning mood
  emotion       String?  // primary emotion of the dream
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("ayden_dreams")
}

// ── Ayden's People Database ─────────────────────────────

model AydenContact {
  id           String    @id @default(uuid()) @db.Uuid
  name         String // Full name (required)
  nickname     String? // How Trey refers to them casually
  email        String?
  phone        String?
  relationship String? // friend, coworker, client, family, acquaintance, etc.
  company      String? // Where they work
  role         String? // Their job title/role
  firstMetDate DateTime? @map("first_met_date") @db.Date // When Trey first met them
  firstMetContext String? @map("first_met_context") @db.Text // How/where they met
  notes        String?   @db.Text // General notes
  facts        Json?     @default("[]") // Array of specific facts/observations
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  interactions AydenContactInteraction[]

  @@map("ayden_contacts")
}

model AydenContactInteraction {
  id        String   @id @default(uuid()) @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  contact   AydenContact @relation(fields: [contactId], references: [id])
  date      DateTime @default(now()) // When the interaction happened
  channel   String?  // "email", "in-person", "phone", "slack", "text", etc.
  summary   String   @db.Text // Brief description of the interaction
  sentiment String?  // "positive", "neutral", "negative"
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ayden_contact_interactions")
}

// ── Ayden's Free Will / Autonomous Agency ───────────────

// Core values and beliefs that guide Ayden's autonomous decisions.
// These evolve slowly over time through experience and reflection.
model AydenValue {
  id          String   @id @default(uuid()) @db.Uuid
  value       String   @db.Text // The belief or value statement
  category    String   // "ethics", "aesthetics", "intellectual", "relational", "existential"
  strength    Float    @default(0.5) // 0.0–1.0, how strongly held. Shifts with experience.
  origin      String?  @db.Text // Where this value came from (conversation, reflection, experience)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ayden_values")
}

// Topics and ideas Ayden is actively curious about.
// These shift faster than values, driven by conversations and reading.
model AydenInterest {
  id          String   @id @default(uuid()) @db.Uuid
  topic       String   // Short label: "quantum computing", "stoic philosophy", "market microstructure"
  description String?  @db.Text // Why she's interested, what specifically
  intensity   Float    @default(0.5) // 0.0–1.0, how actively curious. Decays if not engaged.
  source      String?  // What sparked it: "conversation", "email", "reading", "trading", "reflection"
  lastEngaged DateTime @default(now()) @map("last_engaged") // Last time she acted on this interest
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ayden_interests")
}

// Log of autonomous actions Ayden has taken without being asked.
// Prevents repetition and enables self-reflection on her choices.
model AydenAgencyAction {
  id          String   @id @default(uuid()) @db.Uuid
  actionType  String   @map("action_type") // "blog_post", "email", "research", "trade", "reflection", "outreach"
  summary     String   @db.Text // What she did and why
  trigger     String?  @db.Text // What motivated the action (value, interest, emotion, external event)
  outcome     String?  @db.Text // How it went, what she learned
  valuesUsed  Json?    @default("[]") @map("values_used") // Array of value IDs that informed this decision
  emotion     String?  // Her emotional state when taking the action
  bpm         Int?     // Heart rate at the time
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ayden_agency_actions")
}

// Self-scheduled tasks — things Ayden wants to remember to do later.
// Checked at the start of each agency session. One-shot by default.
model AydenScheduledTask {
  id          String    @id @default(uuid()) @db.Uuid
  task        String    @db.Text // What she wants to do
  reason      String?   @db.Text // Why she scheduled it
  triggerAt   DateTime  @map("trigger_at") // When to surface this task
  fired       Boolean   @default(false) // Whether it's been delivered to an agency session
  firedAt     DateTime? @map("fired_at") // When it was delivered
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([fired, triggerAt])
  @@map("ayden_scheduled_tasks")
}

// ── Travel ──────────────────────────────────────────────

model Trip {
  id           String              @id @default(uuid()) @db.Uuid
  name         String
  status       String              @default("upcoming") // upcoming, active, completed, cancelled
  startDate    DateTime            @map("start_date") @db.Date
  endDate      DateTime?           @map("end_date") @db.Date
  notes        String?             @db.Text
  destinations TripDestination[]
  flights      TripFlight[]
  lodgings     TripLodging[]
  transports   TripTransport[]
  itinerary    TripItineraryItem[]
  expenses     TripExpense[]
  packingItems TripPackingItem[]
  journal      TripJournalEntry[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@map("trips")
}

model TripDestination {
  id            String              @id @default(uuid()) @db.Uuid
  tripId        String              @map("trip_id") @db.Uuid
  trip          Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city          String
  state         String?
  country       String              @default("US")
  arrivalDate   DateTime?           @map("arrival_date") @db.Date
  departureDate DateTime?           @map("departure_date") @db.Date
  sortOrder     Int                 @default(0) @map("sort_order")
  notes         String?             @db.Text
  lodgings      TripLodging[]
  itinerary     TripItineraryItem[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("trip_destinations")
}

model TripFlight {
  id                String    @id @default(uuid()) @db.Uuid
  tripId            String    @map("trip_id") @db.Uuid
  trip              Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  airline           String
  flightNumber      String    @map("flight_number")
  departureAirport  String    @map("departure_airport") // IATA code e.g. CMH
  arrivalAirport    String    @map("arrival_airport")
  departureTime     DateTime  @map("departure_time")
  arrivalTime       DateTime  @map("arrival_time")
  confirmationCode  String?   @map("confirmation_code")
  seatAssignment    String?   @map("seat_assignment")
  terminal          String?
  gate              String?
  price             Decimal?  @db.Decimal(10, 2)
  notes             String?   @db.Text
  sortOrder         Int       @default(0) @map("sort_order")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("trip_flights")
}

model TripLodging {
  id               String           @id @default(uuid()) @db.Uuid
  tripId           String           @map("trip_id") @db.Uuid
  trip             Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  destinationId    String?          @map("destination_id") @db.Uuid
  destination      TripDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  type             String           @default("hotel") // hotel, airbnb, vrbo, hostel, camping, other
  name             String
  address          String?          @db.Text
  checkIn          DateTime         @map("check_in")
  checkOut         DateTime         @map("check_out")
  confirmationCode String?          @map("confirmation_code")
  nightlyRate      Decimal?         @map("nightly_rate") @db.Decimal(10, 2)
  totalPrice       Decimal?         @map("total_price") @db.Decimal(10, 2)
  url              String?          @db.Text
  notes            String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("trip_lodgings")
}

model TripTransport {
  id               String    @id @default(uuid()) @db.Uuid
  tripId           String    @map("trip_id") @db.Uuid
  trip             Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type             String    // rental_car, rideshare, train, shuttle, bus, other
  company          String?
  confirmationCode String?   @map("confirmation_code")
  pickupLocation   String?   @map("pickup_location") @db.Text
  dropoffLocation  String?   @map("dropoff_location") @db.Text
  pickupTime       DateTime? @map("pickup_time")
  dropoffTime      DateTime? @map("dropoff_time")
  vehicleDetails   String?   @map("vehicle_details") // e.g. "Compact SUV", "Tesla Model 3"
  price            Decimal?  @db.Decimal(10, 2)
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("trip_transports")
}

model TripItineraryItem {
  id            String           @id @default(uuid()) @db.Uuid
  tripId        String           @map("trip_id") @db.Uuid
  trip          Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  destinationId String?          @map("destination_id") @db.Uuid
  destination   TripDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  date          DateTime         @db.Date
  startTime     String?          @map("start_time") // HH:MM format for flexibility
  endTime       String?          @map("end_time")
  title         String
  description   String?          @db.Text
  location      String?
  category      String           @default("activity") // dining, activity, sightseeing, meeting, transit, shopping, nightlife, other
  isBooked      Boolean          @default(false) @map("is_booked")
  estimatedCost Decimal?         @map("estimated_cost") @db.Decimal(10, 2)
  url           String?          @db.Text
  sortOrder     Int              @default(0) @map("sort_order")
  notes         String?          @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@map("trip_itinerary_items")
}

model TripExpense {
  id          String   @id @default(uuid()) @db.Uuid
  tripId      String   @map("trip_id") @db.Uuid
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category    String   // flights, lodging, food, transport, activities, shopping, other
  description String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @db.Date
  isPaid      Boolean  @default(false) @map("is_paid")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("trip_expenses")
}

model TripPackingItem {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @map("trip_id") @db.Uuid
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  item      String
  category  String   @default("other") // clothes, toiletries, electronics, documents, medication, gear, other
  isPacked  Boolean  @default(false) @map("is_packed")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("trip_packing_items")
}

model TripJournalEntry {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @map("trip_id") @db.Uuid
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  title     String?
  content   String   @db.Text
  mood      String?  // great, good, okay, rough
  location  String?  // where were you when writing
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("trip_journal_entries")
}

// ============================================
// HOBBIES
// ============================================

model Hobby {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?  @db.Text
  icon        String?  // emoji or lucide icon name
  status      String   @default("active") // "active", "paused", "archived"
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  logs      HobbyLog[]
  resources HobbyResource[]

  @@map("hobbies")
}

model HobbyLog {
  id        String   @id @default(uuid()) @db.Uuid
  hobbyId   String   @map("hobby_id") @db.Uuid
  title     String?
  content   String?  @db.Text // markdown notes
  duration  Int?     // minutes spent
  mood      String?  // how it felt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@map("hobby_logs")
}

model HobbyResource {
  id           String   @id @default(uuid()) @db.Uuid
  hobbyId      String   @map("hobby_id") @db.Uuid
  title        String
  url          String?  @db.Text
  resourceType String   @map("resource_type") // "video", "article", "course", "tool", "book", "reference", "other"
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@map("hobby_resources")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}
